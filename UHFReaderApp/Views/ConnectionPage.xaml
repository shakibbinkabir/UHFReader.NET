<Page
    x:Class="UHFReaderApp.Views.ConnectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Page Title -->
        <TextBlock Grid.Row="0" 
                  Text="Reader Connection" 
                  Style="{ThemeResource HeaderTextBlockStyle}" 
                  Margin="0,0,0,20"/>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="30">
                
                <!-- Network Connection Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                       CornerRadius="8" 
                       Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Network Connection (TCP/IP)" 
                                  Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="IP Address:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                    x:Name="IpAddressTextBox" 
                                    Text="192.168.50.52" 
                                    PlaceholderText="Enter IP address"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Port:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,10,10,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" 
                                    x:Name="PortTextBox" 
                                    Text="6000" 
                                    PlaceholderText="Enter port number"
                                    Margin="0,10,0,0"/>
                            
                            <StackPanel Grid.Row="2" Grid.Column="1" 
                                       Orientation="Horizontal" 
                                       Spacing="10" 
                                       Margin="0,15,0,0">
                                <Button x:Name="ConnectNetworkButton" 
                                       Content="Connect" 
                                       Click="ConnectNetworkButton_Click"
                                       Style="{ThemeResource AccentButtonStyle}"/>
                                <Button x:Name="DisconnectNetworkButton" 
                                       Content="Disconnect" 
                                       Click="DisconnectNetworkButton_Click"
                                       IsEnabled="False"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="3" Grid.Column="1" 
                                     x:Name="NetworkStatusText" 
                                     Text="Disconnected" 
                                     Foreground="Gray" 
                                     Margin="0,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Serial Connection Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                       CornerRadius="8" 
                       Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Serial Connection (COM Port)" 
                                  Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="COM Port:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                    x:Name="SerialPortTextBox" 
                                    Text="1" 
                                    PlaceholderText="Enter COM port number"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Baud Rate:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,10,10,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" 
                                     x:Name="BaudRateComboBox" 
                                     SelectedIndex="3"
                                     Margin="0,10,0,0">
                                <ComboBoxItem Content="9600"/>
                                <ComboBoxItem Content="19200"/>
                                <ComboBoxItem Content="38400"/>
                                <ComboBoxItem Content="57600"/>
                                <ComboBoxItem Content="115200"/>
                            </ComboBox>
                            
                            <StackPanel Grid.Row="2" Grid.Column="1" 
                                       Orientation="Horizontal" 
                                       Spacing="10" 
                                       Margin="0,15,0,0">
                                <Button x:Name="ConnectSerialButton" 
                                       Content="Connect" 
                                       Click="ConnectSerialButton_Click"
                                       Style="{ThemeResource AccentButtonStyle}"/>
                                <Button x:Name="DisconnectSerialButton" 
                                       Content="Disconnect" 
                                       Click="DisconnectSerialButton_Click"
                                       IsEnabled="False"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="3" Grid.Column="1" 
                                     x:Name="SerialStatusText" 
                                     Text="Disconnected" 
                                     Foreground="Gray" 
                                     Margin="0,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Connection Info Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                       CornerRadius="8" 
                       Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Connection Information" 
                                  Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        <TextBlock TextWrapping="Wrap" 
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            Connect to your UHF RFID reader via network (TCP/IP) or serial (COM) port.
                            <LineBreak/>
                            Network connection is typically used for networked readers.
                            <LineBreak/>
                            Serial connection is used for USB or RS232 connected readers.
                        </TextBlock>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>